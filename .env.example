# TransitOps environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ---- Database (local PostgreSQL — no BaaS, per hackathon rules) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://transitops:transitops@localhost:5432/transitops?schema=public"

# ---- Auth (used from Phase 1 onward) ----
# Generate a strong secret, e.g. `openssl rand -base64 48`
JWT_SECRET="change-me-in-your-local-env-min-32-chars-long"
# Access token lifetime
JWT_EXPIRES_IN="1d"

# ---- App ----
# NOTE: Do NOT set NODE_ENV here — Node/Next set it per command (dev vs. build).
# Pinning it in .env poisons `next build` (uses React dev bundles) and breaks the build.
# Public base URL of the app
APP_URL="http://localhost:3000"
